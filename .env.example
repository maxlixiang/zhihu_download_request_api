# 复制为 .env 后填写。命令行参数会覆盖这里的配置。

# 可以直接填知乎主页；程序会自动解析 /people/ 后面的 user_id。
ZHIHU_HOMEPAGE=https://www.zhihu.com/people/mr-dang-77

# 如果不想填主页，也可以直接填 user_id。
# ZHIHU_USER_ID=mr-dang-77

ZHIHU_AUTHOR_NAME=MR Dang
ZHIHU_OUTPUT_DIR=知乎_MR Dang_文章合集(含本地图片)

# 下载类型：
# articles=用户文章，answers=用户回答，pins=用户想法。
# ZHIHU_TYPE=articles

# 可选：只抓取最新 N 篇。
# ZHIHU_COUNT=5

# 可选：只抓取日期区间内的内容，格式 YYYYMMDD。
# ZHIHU_START_DATE=20260101
# ZHIHU_END_DATE=20260201

# 默认防风控延迟区间。命令行传 --delay 会覆盖列表分页和单篇文章处理间隔；
# 命令行传 --image-delay 会覆盖图片下载间隔。
ZHIHU_LIST_DELAY_MIN=2
ZHIHU_LIST_DELAY_MAX=4
ZHIHU_ARTICLE_DELAY_MIN=1.5
ZHIHU_ARTICLE_DELAY_MAX=3
ZHIHU_IMAGE_DELAY_MIN=1
ZHIHU_IMAGE_DELAY_MAX=2

# Cookie 建议写到 cookie.json。也可以临时用环境变量：
# ZHIHU_COOKIE=_xsrf=...; z_c0=...; SESSIONID=...

# 如果你的 Cookie JSON 文件不在当前目录，可以指定路径。
# ZHIHU_COOKIE_JSON=F:\path\to\cookie.json
